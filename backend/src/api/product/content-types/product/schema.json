{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "product",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "minLength": 3
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "integer"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Men",
        "Women"
      ]
    },
    "slug": {
      "type": "uid",
      "required": true
    },
    "size": {
      "type": "string",
      "maxLength": 70
    },
    "color": {
      "type": "enumeration",
      "enum": [
        "red",
        "green",
        "yellow",
        "gray",
        "blue",
        "teal",
        "stone",
        "emerald",
        "slate"
      ]
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
